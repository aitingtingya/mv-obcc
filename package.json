{
  "name": "mv-obcc",
  "version": "0.8.0",
  "description": "A focused Claude Code and Codex CLI IDE bridge for local vaults.",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "build": "node esbuild.config.mjs production",
    "dev": "node esbuild.config.mjs",
    "lint": "eslint main.ts src",
    "typecheck": "tsc --noEmit",
    "verify": "npm run lint && npm run typecheck && npm run build",
    "deploy:local": "npm run build && node scripts/deploy-local.mjs",
    "package": "node scripts/package.mjs"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "6.9.0",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/language": "^6.12.4",
    "@codemirror/lint": "6.8.5",
    "@codemirror/merge": "^6.12.1",
    "@codemirror/search": "^6.7.1",
    "@lezer/common": "^1.5.2",
    "@popperjs/core": "^2.11.5",
    "@xterm/addon-fit": "^0.11.0",
    "js-base64": "^3.8.0",
    "valibot": "^0.24.1",
    "ws": "^8.18.3",
    "xterm": "^5.3.0"
  },
  "overrides": {
    "@codemirror/state": "6.5.0",
    "@codemirror/view": "6.38.6"
  },
  "devDependencies": {
    "@codemirror/state": "6.5.0",
    "@codemirror/view": "6.38.6",
    "@types/archiver": "^6.0.3",
    "@types/node": "^22.18.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/parser": "^8.61.0",
    "archiver": "^7.0.1",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.4",
    "eslint-plugin-obsidianmd": "^0.3.0",
    "obsidian": "1.13.1",
    "typescript": "^5.9.2"
  }
}
